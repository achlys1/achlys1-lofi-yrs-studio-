<p>import streamlit as st
import librosa
import numpy as np</p>
<h1>1. Page Configuration for Mobile</h1>
<p>st.set_page_config(page_title="AI Lofi Studio", page_icon="рЯОµ", layout="centered")</p>
<p>st.title("рЯОµ AI Lofi Studio")
st.write("Extract the best parts of any song for your Lofi beats.")</p>
<h1>2. File Uploader</h1>
<p>uploaded_file = st.file_uploader("Choose a music file", type=["mp3", "wav"])</p>
<p>if uploaded_file:
with st.spinner("AI is analyzing the track..."):
# Load the audio data
y, sr = librosa.load(uploaded_file)</p>
<div class="_codeSnippet_1o8d5_1"><div class="_preContainer_1o8d5_5"><pre><span class="line" data-line=""><span style="color:#8E8E8EFF">    # BPM Detection</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    tempo, _ </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> librosa.beat.beat_track(</span><span style="color:#FFD395FF">y</span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF">y, </span><span style="color:#FFD395FF">sr</span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF">sr)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    st.metric(</span><span style="color:#FFD395FF">label</span><span style="color:#FD8DA3FF">=</span><span style="color:#77D5A3FF">"Detected Tempo"</span><span style="color:#E1DFDFFF">, </span><span style="color:#FFD395FF">value</span><span style="color:#FD8DA3FF">=</span><span style="color:#FD8DA3FF">f</span><span style="color:#77D5A3FF">"</span><span style="color:#8DA8FFFF">{round</span><span style="color:#E1DFDFFF">(</span><span style="color:#8DA8FFFF">float</span><span style="color:#E1DFDFFF">(tempo), </span><span style="color:#8DA8FFFF">2</span><span style="color:#E1DFDFFF">)</span><span style="color:#8DA8FFFF">}</span><span style="color:#77D5A3FF"> BPM"</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">    # 3. The Stanza Finder (Structural Segmentation)</span></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">    # This analyzes the 'percussive' energy to find section changes</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    y_percussive </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> librosa.effects.hpss(y)[</span><span style="color:#8DA8FFFF">1</span><span style="color:#E1DFDFFF">]</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    onset_env </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> librosa.onset.onset_strength(</span><span style="color:#FFD395FF">y</span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF">y_percussive, </span><span style="color:#FFD395FF">sr</span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF">sr)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    </span></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">    # Find 5 major structural boundaries</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    boundaries </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> librosa.segment.agglomerative(onset_env, </span><span style="color:#8DA8FFFF">5</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    boundary_times </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> librosa.frames_to_time(boundaries, </span><span style="color:#FFD395FF">sr</span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF">sr)</span></span>
<span class="line" data-line=""></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    st.subheader(</span><span style="color:#77D5A3FF">"Detected Song Sections"</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    </span></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">    # Loop through boundaries to show timestamps</span></span>
<span class="line" data-line=""><span style="color:#FD8DA3FF">    for</span><span style="color:#E1DFDFFF"> i </span><span style="color:#FD8DA3FF">in</span><span style="color:#8DA8FFFF"> range</span><span style="color:#E1DFDFFF">(</span><span style="color:#8DA8FFFF">len</span><span style="color:#E1DFDFFF">(boundary_times)</span><span style="color:#FD8DA3FF">-</span><span style="color:#8DA8FFFF">1</span><span style="color:#E1DFDFFF">):</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">        start </span><span style="color:#FD8DA3FF">=</span><span style="color:#8DA8FFFF"> round</span><span style="color:#E1DFDFFF">(boundary_times[i], </span><span style="color:#8DA8FFFF">2</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">        end </span><span style="color:#FD8DA3FF">=</span><span style="color:#8DA8FFFF"> round</span><span style="color:#E1DFDFFF">(boundary_times[i</span><span style="color:#FD8DA3FF">+</span><span style="color:#8DA8FFFF">1</span><span style="color:#E1DFDFFF">], </span><span style="color:#8DA8FFFF">2</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">        duration </span><span style="color:#FD8DA3FF">=</span><span style="color:#8DA8FFFF"> round</span><span style="color:#E1DFDFFF">(end </span><span style="color:#FD8DA3FF">-</span><span style="color:#E1DFDFFF"> start, </span><span style="color:#8DA8FFFF">2</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">        </span></span>
<span class="line" data-line=""><span style="color:#FD8DA3FF">        with</span><span style="color:#E1DFDFFF"> st.expander(</span><span style="color:#FD8DA3FF">f</span><span style="color:#77D5A3FF">"Section </span><span style="color:#8DA8FFFF">{</span><span style="color:#E1DFDFFF">i</span><span style="color:#FD8DA3FF">+</span><span style="color:#8DA8FFFF">1}</span><span style="color:#77D5A3FF"> (</span><span style="color:#8DA8FFFF">{</span><span style="color:#E1DFDFFF">duration</span><span style="color:#8DA8FFFF">}</span><span style="color:#77D5A3FF">s)"</span><span style="color:#E1DFDFFF">):</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">            st.write(</span><span style="color:#FD8DA3FF">f</span><span style="color:#77D5A3FF">"Starts at: </span><span style="color:#8DA8FFFF">{</span><span style="color:#E1DFDFFF">start</span><span style="color:#8DA8FFFF">}</span><span style="color:#77D5A3FF">s | Ends at: </span><span style="color:#8DA8FFFF">{</span><span style="color:#E1DFDFFF">end</span><span style="color:#8DA8FFFF">}</span><span style="color:#77D5A3FF">s"</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">            # In a full app, we would add a 'Play' button for this segment here</span></span>
<span class="line" data-line=""></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">    # 4. Loop Recommendation</span></span>
<span class="line" data-line=""><span style="color:#8E8E8EFF">    # Usually, the longest consistent section is best for a Lofi loop</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    durations </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> np.diff(boundary_times)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    best_idx </span><span style="color:#FD8DA3FF">=</span><span style="color:#E1DFDFFF"> np.argmax(durations)</span></span>
<span class="line" data-line=""><span style="color:#E1DFDFFF">    st.success(</span><span style="color:#FD8DA3FF">f</span><span style="color:#77D5A3FF">"рЯФ• AI Recommendation: Use Section </span><span style="color:#8DA8FFFF">{</span><span style="color:#E1DFDFFF">best_idx</span><span style="color:#FD8DA3FF">+</span><span style="color:#8DA8FFFF">1}</span><span style="color:#77D5A3FF"> for your loop."</span><span style="color:#E1DFDFFF">)</span></span></pre></div><div class="_codeSnippetToolbar_1o8d5_51"><div class="_text_65zw6_7 _l4_65zw6_98">python (auto)</div><vscode-button id="icon-button-5143491" class="_iconButton_1n4c3_1" current-value="" appearance="icon" aria-label="Copy to Clipboard"><template shadowmode="open" shadowdelegatesfocus="">
