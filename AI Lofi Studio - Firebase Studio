<span class="line" data-line=""></span>
<span class="line" data-line=""><span style="color:#8DA8FFFF">print</span><span style="color:#E1DFDFFF">(</span><span style="color:#FD8DA3FF">f</span><span style="color:#77D5A3FF">"Detected Tempo: </span><span style="color:#8DA8FFFF">{round</span><span style="color:#E1DFDFFF">(</span><span style="color:#8DA8FFFF">float</span><span style="color:#E1DFDFFF">(tempo), </span><span style="color:#8DA8FFFF">2</span><span style="color:#E1DFDFFF">)</span><span style="color:#8DA8FFFF">}</span><span style="color:#77D5A3FF"> BPM"</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""></span>
<span class="line" data-line=""><span style="color:#FD8DA3FF">if</span><span style="color:#E1DFDFFF"> tempo </span><span style="color:#FD8DA3FF">&gt;</span><span style="color:#8DA8FFFF"> 100</span><span style="color:#E1DFDFFF">:</span></span>
<span class="line" data-line=""><span style="color:#8DA8FFFF">    print</span><span style="color:#E1DFDFFF">(</span><span style="color:#77D5A3FF">"Suggestion: This is a bit fast for Lofi. We should slow it down!"</span><span style="color:#E1DFDFFF">)</span></span>
<span class="line" data-line=""><span style="color:#FD8DA3FF">else</span><span style="color:#E1DFDFFF">:</span></span>
